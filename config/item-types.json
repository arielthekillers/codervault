    },
    "reminder": {
        "label": "Reminder",
        "icon": "bi-alarm",
        "color": "#eab308",
        "fields": [
            { "name": "tanggal", "label": "Tanggal / Tenggat Waktu", "type": "date", "required": true }
        ]
    },
    "reference": {
        "label": "Reference Link",
        "icon": "bi-link-45deg",
        "color": "#14b8a6",
        "fields": [
            { "name": "url", "label": "URL Tautan", "type": "url", "required": true },
            { "name": "bookmark", "label": "Tambahkan ke Bookmark Utama", "type": "checkbox", "required": false }
        ]
